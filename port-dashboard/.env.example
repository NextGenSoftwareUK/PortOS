# LFG Port OS Dashboard — environment variables
# Copy to .env and fill in values. Never commit .env.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3120
PORT_SITE=abidjan           # site identifier shown in the dashboard
REFRESH_INTERVAL_SEC=60     # how often the full KPI sweep runs (min 15)
SIM_INTERVAL_SEC=12         # how often the holon simulator ticks (min 10)

# ── OASIS API (Phase 2 — required for persistent holons) ─────────────────────
# Docs: https://api.oasisweb4.com/swagger/index.html
OASIS_API_URL=https://api.oasisweb4.com
OASIS_JWT=                  # JWT from POST /api/avatar/authenticate
